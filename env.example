# ─── Server ─────────────────────────────────────
SECRET_KEY=your-secret-key-change-me
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# ─── Search Radius ──────────────────────────────
SEARCH_RADIUS_KM=15

# ─── Scoring Weights (must sum to 1.0) ──────────
WEIGHT_FACILITY=0.30
WEIGHT_DISTANCE=0.20
WEIGHT_BEDS=0.20
WEIGHT_SPECIALIST=0.15
WEIGHT_PREDICTION=0.10
WEIGHT_HISTORY=0.05

# ─── Google Maps API (optional) ─────────────────
GOOGLE_MAPS_API_KEY=

# ─── Firebase Auth (optional for dev) ───────────
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_SERVICE_ACCOUNT_PATH=

# ─── Driver Settings ────────────────────────────
DRIVER_ACCEPT_TIMEOUT_SEC=45
LOCATION_UPDATE_INTERVAL_SEC=5
